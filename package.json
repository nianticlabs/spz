{
  "name": "@3di/spz",
  "version": "0.0.7",
  "description": "WebAssembly module for loading Gaussian splat (SPZ) files",
  "main": "dist/spz.js",
  "types": "dist/spz.d.ts",
  "scripts": {
    "prebuild": "rm -rf ./dist",
    "publishPackage": "npm publish --registry https://artifactory.corp.adobe.com/artifactory/api/npm/npm-adobe-release-local",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/spz.d.ts",
      "default": "./dist/spz.js"
    }
  },
  "keywords": [
    "wasm",
    "emscripten",
    "gaussian-splatting",
    "3d"
  ],
  "author": "Adobe Inc.",
  "license": "ISC",
  "homepage": "https://git.corp.adobe.com/thirdparty/spz",
  "publishConfig": {
    "@3di:registry": "https://artifactory.corp.adobe.com/artifactory/api/npm/npm-adobe-release-local"
  }
}
